{
  "expo": {
    "name": "Control Box",
    "slug": "checklistjabil",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/app/images/checklist jabil.png",
    "scheme": "checklistjabil",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./src/app/images/checklist jabil.png"
    },
    "android": {
      "icon": "./src/app/images/checklist jabil.png",
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.checklistjabil"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
